# Konfiguration des Pausenaufsicht-Planers. Diese Datei nach `.env` kopieren
# und die Werte ausfüllen. NIEMALS echte Zugangsdaten committen — `.env` ist
# in .gitignore.

# HTTP
PORT=3000

# Session-Signatur (langer Zufallswert, z. B. `openssl rand -hex 32`)
SESSION_SECRET=bitte-einen-langen-zufallswert-eintragen

# Schlüssel für die Verschlüsselung der Lehrerdaten in der Datenbank.
# ACHTUNG: Bei bestehender Datenbank NICHT ändern, sonst sind die
# gespeicherten Namen nicht mehr lesbar.
ENCRYPTION_KEY=bitte-einen-langen-zufallswert-eintragen

# ============================================================
# LDAP / Active Directory (sobald LDAP_URL gesetzt ist, läuft die
# Anmeldung über das AD; Lehrkräfte werden beim ersten Login
# automatisch angelegt — teacher.csv wird nicht mehr benötigt)
# ============================================================
LDAP_URL=ldaps://dc01.schule.local:636
LDAP_BASE_DN=DC=schule,DC=local
# {{username}} wird durch die Anmeldekennung ersetzt (AD: sAMAccountName)
LDAP_USER_FILTER=(sAMAccountName={{username}})

# --- Variante A: Direkt-Bind (empfohlen, kein Service-Account nötig) ---
# Der Nutzer bindet direkt mit eigener Kennung + Passwort. {{username}} wird
# ersetzt. NetBIOS-Form (z. B. SNRD\{{username}}) oder UPN ({{username}}@snrd.local).
LDAP_BIND_USER_TEMPLATE=SNRD\{{username}}

# --- Variante B: Service-Account (nur falls KEIN Direkt-Bind genutzt wird) ---
# Bei gesetztem LDAP_BIND_USER_TEMPLATE werden diese beiden ignoriert.
#LDAP_BIND_DN=CN=svc-pausenaufsicht,OU=ServiceAccounts,DC=schule,DC=local
#LDAP_BIND_PW=

LDAP_LOGIN_ATTR=sAMAccountName
LDAP_NAME_ATTR=displayName
# TLS für ldaps:// — bei interner CA den Pfad zur CA-PEM angeben (empfohlen):
#LDAP_TLS_CA_PFAD=/pfad/zur/interne-ca.pem
# Notlösung (nur in vertrauenswürdigen Netzen): Zertifikatsprüfung abschalten:
#LDAP_TLS_REJECT_UNAUTHORIZED=false

# Admin-Berechtigungen im LDAP-Modus: Komma-getrennte Anmeldekennungen
# (Kürzel), Groß-/Kleinschreibung egal. Beispiel: ADMIN_USERS=MustM,SchmiA
ADMIN_USERS=

# ============================================================
# Legacy-Modus (nur wenn LDAP_URL NICHT gesetzt ist, z. B. für
# lokale Entwicklung): gemeinsames Passwort wie bisher
# ============================================================
#USER_PASSWORD=
#ADMIN_PASSWORD=
